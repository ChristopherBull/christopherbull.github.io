{
  "name": "dev-christopherbull.github.io",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers-extra/features/mise:1": {}
  },
  "forwardPorts": [
    4000
  ],
  "portsAttributes": {
    "4000": {
      "label": "Jekyll dev server",
      "onAutoForward": "openBrowser"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "davidanson.vscode-markdownlint",
        "joshbolduc.commitlint",
        "streetsidesoftware.code-spell-checker"
      ]
    }
  },
  "mounts": [
    {
      "source": "mise-data-volume",
      "target": "/mnt/mise-data",
      "type": "volume"
    }
  ],
  "containerEnv": {
    "CHROME_PATH": "/usr/bin/google-chrome-stable",
    "LANG": "C.UTF-8",
    "LC_ALL": "C.UTF-8",
    "MISE_DATA_DIR": "/mnt/mise-data",
    // Disable GPG signature verification for Node installation. Mise does not handle
    // GPG key verification automatically, so keys would otherwise require manual
    // downloading and configuration. This avoids that complexity.
    "MISE_NODE_GPG_VERIFY": "0"
  },
  "remoteEnv": {
    // Keep the GitHub token as a runtime-only value so it is available in local
    // and CI containers without being baked into the container image metadata.
    "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}",
    "PATH": "${containerEnv:PATH}:/mnt/mise-data/shims"
  },
  // Lifecycle commands
  // Keep both: postinstall hooks run on tool install/update, while postCreate
  // always runs tool install plus dependency install for each container build.
  "onCreateCommand": ".devcontainer/scripts/onCreate.sh",
  "postCreateCommand": "mise run install-deps"
}
